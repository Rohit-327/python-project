pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/your/repo.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t yourdockerhub/devops-app:v1 .'
            }
        }

        stage('Push Image') {
            steps {
                sh 'docker push yourdockerhub/devops-app:v1'
            }
        }

        stage('Deploy to K8s') {
            steps {
                sh 'kubectl apply -f deployment.yaml'
            }
        }
    }
}